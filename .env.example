# Copy this file to .env and fill in the real RDS PostgreSQL values.
# Do not commit .env.

MES_DB_HOST=pgm-xxxxxxxx.pg.rds.aliyuncs.com
MES_DB_PORT=5432
MES_DB_NAME=MESSystem
MES_DB_USER=MESSystem
MES_DB_PASSWORD=replace_with_real_password
MES_PUBLIC_URL=http://127.0.0.1:18080
MES_TRACE_STORAGE=storage/trace

# 阿里云百炼 OpenAI Compatible API，用于 PMC 排产辅助建议。
# Base URL 只写到 /compatible-mode/v1，不要追加 /chat/completions。
AI_PLANNING_ENABLED=false
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_API_KEY=replace_with_new_dashscope_key
