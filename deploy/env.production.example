# Copy this file to /www/wwwroot/mes/.env or set the same variables in Supervisor.
# Do not commit real passwords.

MES_DB_HOST=your-rds-postgresql-host
MES_DB_PORT=5432
MES_DB_NAME=MESSystem
MES_DB_USER=MESSystem
MES_DB_PASSWORD=replace_with_real_password

MES_HOST=127.0.0.1
MES_PORT=8080
MES_OPEN_BROWSER=false
MES_PUBLIC_URL=http://119.45.196.92/

# 阿里云百炼 OpenAI Compatible API，用于 PMC 排产辅助建议。
# Base URL 只写到 /compatible-mode/v1，不要追加 /chat/completions。
AI_PLANNING_ENABLED=false
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_API_KEY=replace_with_new_dashscope_key
